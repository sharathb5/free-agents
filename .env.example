# =============================================================================
# Core
# =============================================================================

# Which preset to load (summarizer | meeting_notes | extractor | classifier | triage)
AGENT_PRESET=summarizer

# Provider backend (stub | openrouter | openai)
PROVIDER=stub

# Legacy static bearer token for dev/test auth (optional)
AUTH_TOKEN=

# =============================================================================
# Providers
# =============================================================================

# OpenRouter (recommended — one key for many models)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Direct OpenAI (alternative to OpenRouter)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# =============================================================================
# Auth (Clerk)
# =============================================================================

# Clerk JWKS endpoint for verifying session tokens (same Clerk application as frontend)
CLERK_JWKS_URL=

# Alternative: Clerk JWT public key as PEM (use instead of JWKS URL if preferred)
CLERK_JWT_KEY=

# Must exactly match the `iss` claim in session JWTs (omit to skip issuer check)
CLERK_ISSUER=

# Leave unset unless you know the `aud` claim (wrong value causes JWT audience invalid)
CLERK_AUDIENCE=

# Comma-separated `azp` allowlist (optional)
CLERK_AUTHORIZED_PARTIES=

# Clerk secret key — required for /github/repos to fetch user's GitHub token via Clerk
# Use sk_test_* for local dev, sk_live_* for production
CLERK_SECRET_KEY=

# =============================================================================
# Database
# =============================================================================

# Postgres connection string (Supabase or any PG). When set, overrides SQLite.
DATABASE_URL=

# SQLite DB path when DATABASE_URL is not set
DB_PATH=./data/gateway.db

# Legacy alias for DB_PATH (still supported)
SESSION_DB_PATH=

# =============================================================================
# CORS
# =============================================================================

# Comma-separated allowed origins for CORS (default: * for dev)
CORS_ORIGINS=http://localhost:3000

# =============================================================================
# GitHub OAuth (legacy popup path — not needed if using Clerk's GitHub token)
# =============================================================================

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://localhost:4280/github/oauth/callback

# Comma-separated frontend origins allowed for postMessage (localhost always allowed)
GITHUB_OAUTH_ALLOWED_RETURN_ORIGINS=

# =============================================================================
# Frontend (goes in frontend/.env.local, NOT the root .env)
# =============================================================================

# Use pk_test_* for local dev on localhost, pk_live_* only on your production domain
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Named JWT template (optional — leave unset for standard session tokens)
NEXT_PUBLIC_CLERK_JWT_TEMPLATE=

# Backend gateway URL the Next.js frontend calls
NEXT_PUBLIC_GATEWAY_URL=http://localhost:4280

# Set to 1 only if the gateway is configured to verify the JWT template's aud/iss
NEXT_PUBLIC_GATEWAY_USE_CLERK_JWT_TEMPLATE=
