# Free Agents: FastAPI (uvicorn :8000) + Next.js (:5000 → external 80).
# Set NEXT_PUBLIC_GATEWAY_URL in Replit Secrets to this Repl’s public API URL (port 8000).
# Merged: deploy --replit baseline + Replit Agent workflows.

entrypoint = "app/main.py"

modules = ["python-3.10", "nodejs-20", "bash", "web"]

[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[packager]
language = "python3"

[packager.features]
guessImports = true

onBoot = "python3 -m pip install -q --upgrade pip --disable-pip-version-check && python3 -m pip install -q -e . --disable-pip-version-check"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "python3 -m uvicorn app.main:app --host 0.0.0.0 --port 8000"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 3000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 5000

[[ports]]
localPort = 8000
externalPort = 80

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]
