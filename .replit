# Generated by `free-agents deploy --replit` / `agent-toolbox deploy --replit`.
# Free Agents (agent-toolbox) gateway — see README and app/cli.py.

entrypoint = "app/main.py"

# Pin matches Replit docs example; update if Replit deprecates this module id.
modules = ["python-3.10:v18-20230807-322e88b"]

[nix]
channel = "stable-23_11"

[packager]
language = "python3"

[packager.features]
guessImports = true

# Editable install on boot: -q is fast on no-op; --disable-pip-version-check avoids slow checks.
# Skips heavy work when nothing changed; still reapplies if pyproject.toml / deps change.
onBoot = "python3 -m pip install -q --upgrade pip --disable-pip-version-check && python3 -m pip install -q -e . --disable-pip-version-check"

run = ["bash", "-c", "exec python3 -m uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-4280}"]

[[ports]]
localPort = 4280
externalPort = 80

[gitHubImport]
requiredFiles = [".replit", "replit.nix"]
